# .gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Database
*.db
*.sqlite3

# Celery
celerybeat-schedule
celerybeat.pid

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Docker
.docker/

# Migration files (keep directory, remove contents)
migrations/versions/*.pyc

# Worker-internal files — NEVER push to GitHub
PROPOSAL.md
COVER_LETTER.txt
SPEC.txt
TASK.txt
pid
role
.planning/
*.pyc
