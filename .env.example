# .env.example - Environment Variables Template
# Copy this file to .env and update values for your environment

# Application
APP_NAME=ap-automation-engine
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ap_automation
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=5432
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Matching Engine Thresholds (0-100)
THRESHOLD_HIGH=90
THRESHOLD_MID=70
THRESHOLD_LOW=50

# Matching Tolerances (percentage)
TOLERANCE_PRICE=5
TOLERANCE_QTY=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
