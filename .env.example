// .env.example
# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ap_automation
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=ap_automation

# PGBouncer Configuration
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=5432

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Matching Thresholds
THRESHOLD_HIGH=95
THRESHOLD_MID=75
THRESHOLD_LOW=50

# Tolerance Settings
TOLERANCE_PRICE=5.0
TOLERANCE_QTY=10.0

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Application Settings
APP_NAME=AP Automation Engine
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
