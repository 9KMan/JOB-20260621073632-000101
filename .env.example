// .env.example
# Database Configuration
DATABASE_URL=postgresql+asyncpg://apuser:appassword@localhost:5432/apautomation
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=apautomation
DATABASE_USER=apuser
DATABASE_PASSWORD=appassword

# PGBouncer Configuration
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Matching Thresholds
THRESHOLD_HIGH=90
THRESHOLD_MID=70
THRESHOLD_LOW=50

# Tolerance Settings
TOLERANCE_PRICE=5
TOLERANCE_QTY=10

# Application Settings
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL (for docker-compose)
POSTGRES_USER=apuser
POSTGRES_PASSWORD=appassword
POSTGRES_DB=apautomation
POSTGRES_PORT=5432
