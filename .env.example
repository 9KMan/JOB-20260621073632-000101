# Application
APP_ENV=development
APP_NAME=FinaRo AP Automation

# Database
DATABASE_URL=postgresql+asyncpg://finaro:secret@localhost:5432/finaro_ap
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Matching Engine Thresholds
THRESHOLD_HIGH=90
THRESHOLD_MID=70
THRESHOLD_LOW=50

# Matching Tolerances
TOLERANCE_PRICE=5.0
TOLERANCE_QTY=10.0

# Learning Loop
LEARNING_ENABLED=true
LEARNING_BATCH_SIZE=100
CONFIRMATION_REQUIRED=true
