# Application
APP_NAME=FinaRo
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finaro
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/finaro
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Matching Configuration
MATCHING_LINE_WEIGHT=0.7
MATCHING_AMOUNT_WEIGHT=0.2
MATCHING_DATE_WEIGHT=0.1
AUTO_APPROVE_THRESHOLD=0.95
HUMAN_REVIEW_THRESHOLD=0.70
