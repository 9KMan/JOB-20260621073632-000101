// .env.example
# Database Configuration
DATABASE_URL=postgresql+asyncpg://apuser:appassword@localhost:5432/apautomation
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Matching Thresholds (0-100)
THRESHOLD_HIGH=95    # Auto-approve threshold
THRESHOLD_MID=75     # 1-click review threshold
THRESHOLD_LOW=50     # Exception threshold

# Tolerance Configuration (percentage)
TOLERANCE_PRICE=5    # Price match tolerance %
TOLERANCE_QTY=10     # Quantity match tolerance %

# Application Settings
LOG_LEVEL=INFO
DEBUG=false
API_V1_PREFIX=/api/v1
PROJECT_NAME=AP Automation Core Engine
VERSION=0.1.0

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
