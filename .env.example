# .env.example
# Database
DATABASE_URL=postgresql+asyncpg://finaro:password@localhost:5432/finaro_ap
DATABASE_URL_SYNC=postgresql://finaro:password@localhost:5432/finaro_ap

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_NAME=FinaRo AP Automation
APP_VERSION=0.1.0
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Matching Weights (Layer 2)
MATCH_WEIGHT_LINE_LEVEL=0.70
MATCH_WEIGHT_AMOUNT=0.20
MATCH_WEIGHT_DATE=0.10

# Decision Thresholds
THRESHOLD_AUTO_APPROVE=0.95
THRESHOLD_HUMAN_REVIEW=0.70
