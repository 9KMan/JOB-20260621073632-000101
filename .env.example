# .env.example
# Database Configuration
DATABASE_URL=postgresql+asyncpg://apuser:apsecret@localhost:5432/apautomation
POSTGRES_USER=apuser
POSTGRES_PASSWORD=apsecret
POSTGRES_DB=apautomation
POSTGRES_PORT=5432
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# PGBouncer
PGBOUNCER_PORT=6432

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Matching Thresholds (percentages)
THRESHOLD_HIGH=95
THRESHOLD_MID=70
THRESHOLD_LOW=50

# Tolerance Settings (percentages)
TOLERANCE_PRICE=5
TOLERANCE_QTY=10

# Application
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
