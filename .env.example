// .env.example
# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finaro_ap
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_NAME=FinaRo AP Automation
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Matching Weights (percentage)
MATCHING_WEIGHT_LINE_LEVEL=70
MATCHING_WEIGHT_AMOUNT=20
MATCHING_WEIGHT_DATE=10

# Decision Thresholds
AUTO_APPROVE_THRESHOLD=95
HUMAN_REVIEW_THRESHOLD=70
