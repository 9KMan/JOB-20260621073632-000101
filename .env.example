# AP Automation Core Engine - environment variables template
# Copy this file to `.env` and fill in real values for local development.
# Production values MUST come from a secrets manager; never commit a populated .env.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://ap_user:ap_password@pgbouncer:6432/ap_automation
DATABASE_URL_SYNC=postgresql://ap_user:ap_password@localhost:5432/ap_automation
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ap_automation
POSTGRES_USER=ap_user
POSTGRES_PASSWORD=ap_password

# --- Authentication ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Matching thresholds ---
THRESHOLD_HIGH=95
THRESHOLD_MID=80
THRESHOLD_LOW=60

# --- Tolerances ---
TOLERANCE_PRICE=0.02
TOLERANCE_QTY=0.01

# --- Learning loop ---
CROSS_REF_MIN_CONFIRMATIONS=3
CROSS_REF_PROMOTION_THRESHOLD=0.85

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
