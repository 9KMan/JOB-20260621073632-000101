# .env.example - Environment variables for AP Automation

# Database Configuration
DATABASE_URL=postgresql+asyncpg://apuser:appass@localhost:5432/apautomation
POSTGRES_USER=apuser
POSTGRES_PASSWORD=appass
POSTGRES_DB=apautomation
POSTGRES_PORT=5432

# PGBouncer Configuration
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# JWT / Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Matching Thresholds (0-100 scale)
THRESHOLD_HIGH=95
THRESHOLD_MID=70
THRESHOLD_LOW=40

# Tolerance Settings (percentage)
TOLERANCE_PRICE=5
TOLERANCE_QTY=10

# Application Settings
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=false

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Testing
TEST_DATABASE_URL=postgresql+asyncpg://apuser:appass@localhost:5432/apautomation_test
