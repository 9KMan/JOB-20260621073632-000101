# Application
APP_NAME="FinaRo AP Automation"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finaro_ap
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/finaro_ap

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Matching Engine Config
MATCHING_WEIGHT_LINE_LEVEL=0.70
MATCHING_WEIGHT_AMOUNT=0.20
MATCHING_WEIGHT_DATE=0.10
AUTO_APPROVE_THRESHOLD=0.95
HUMAN_REVIEW_THRESHOLD=0.70
