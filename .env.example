// .env.example
# ============================================
# AP Automation Core Engine - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=ap_automation
POSTGRES_USER=apuser
POSTGRES_PASSWORD=changeme-in-production
POSTGRES_PORT=5432
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432

# Direct connection (when not using PGBouncer)
DATABASE_URL=postgresql+asyncpg://apuser:changeme@localhost:5432/ap_automation

# Connection Pool Settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ============================================
# JWT / Security Configuration
# ============================================
# IMPORTANT: Generate a strong secret in production!
# Use: openssl rand -hex 32
JWT_SECRET_KEY=changeme-use-openssl-rand-hex-32-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Matching Engine Thresholds
# ============================================
# Score thresholds for matching decisions (0-100)
THRESHOLD_HIGH=95   # Auto-approve
THRESHOLD_MID=75    # 1-click review
THRESHOLD_LOW=50    # Exception flag

# ============================================
# Matching Engine Tolerances
# ============================================
# Percentage tolerances for price/quantity matching
TOLERANCE_PRICE=5   # Price tolerance percentage
TOLERANCE_QTY=10    # Quantity tolerance percentage

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# Redis (Optional - for caching)
# ============================================
REDIS_PORT=6379
