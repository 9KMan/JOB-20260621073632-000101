# .env.example
# Application
APP_NAME=FinaRo AP Automation
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finaro_ap
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/finaro_ap
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=5432
PGBOUNCER_POOL_SIZE=20

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Matching Engine Configuration
MATCH_WEIGHT_LINE_LEVEL=0.70
MATCH_WEIGHT_AMOUNT=0.20
MATCH_WEIGHT_DATE=0.10
AUTO_APPROVE_THRESHOLD=0.95
HUMAN_REVIEW_THRESHOLD=0.70

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
