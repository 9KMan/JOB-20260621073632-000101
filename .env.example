// .env.example
# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
POSTGRES_USER=apuser
POSTGRES_PASSWORD=appassword
POSTGRES_DB=apautomation
POSTGRES_PORT=5432

# Connection strings (for Docker, use service names; for local, use localhost)
DATABASE_URL=postgresql+asyncpg://apuser:appassword@localhost:5432/apautomation
SYNC_DATABASE_URL=postgresql+psycopg2://apuser:appassword@localhost:5432/apautomation

# PGBouncer (if used)
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Matching Engine Thresholds (0-100)
THRESHOLD_HIGH=90
THRESHOLD_MID=70
THRESHOLD_LOW=50

# Tolerance Settings
TOLERANCE_PRICE=5.0
TOLERANCE_QTY=10.0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# API
API_PORT=8000
PGADMIN_PORT=5050
