# .env.example
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ap_automation
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=5432

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Matching Thresholds
THRESHOLD_HIGH=0.95
THRESHOLD_MID=0.75
THRESHOLD_LOW=0.50

# Tolerance Settings
TOLERANCE_PRICE=0.02
TOLERANCE_QTY=0.10

# Application
LOG_LEVEL=INFO
APP_NAME=AP Automation
APP_VERSION=0.1.0
