# .env.example
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ap_automation
DATABASE_USER=ap_user
DATABASE_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://ap_user:your_secure_password_here@localhost:5432/ap_automation

# PGBouncer Configuration
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Matching Thresholds (percentage scores)
THRESHOLD_HIGH=95
THRESHOLD_MID=70
THRESHOLD_LOW=40

# Tolerance Settings (percentage)
TOLERANCE_PRICE=5.0
TOLERANCE_QTY=10.0

# Logging
LOG_LEVEL=INFO

# Application
APP_NAME=AP Automation Core
APP_VERSION=1.0.0
DEBUG=false
