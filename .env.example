// .env.example
# Database
DATABASE_URL=postgresql+asyncpg://finaro:secure_password@localhost:5432/finaro_ap
DATABASE_URL_SYNC=postgresql://finaro:secure_password@localhost:5432/finaro_ap

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
