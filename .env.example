// .env.example
# Database Configuration
DATABASE_URL=postgresql+asyncpg://apuser:appassword@localhost:5432/apautomation
POSTGRES_USER=apuser
POSTGRES_PASSWORD=appassword
POSTGRES_DB=apautomation
POSTGRES_PORT=5432

# PGBouncer Configuration
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Matching Thresholds (0.0 - 1.0)
THRESHOLD_HIGH=0.95
THRESHOLD_MID=0.75
THRESHOLD_LOW=0.50

# Tolerance Settings
TOLERANCE_PRICE=0.02
TOLERANCE_QTY=0.05

# CORS Configuration
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# Application Settings
API_PORT=8000
ENVIRONMENT=development
