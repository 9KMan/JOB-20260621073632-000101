# Application Settings
APP_NAME=ap-automation-engine
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ap_automation
# Alternative using PGBouncer:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:6432/ap_automation

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Matching Engine Thresholds (percentages)
THRESHOLD_HIGH=90
THRESHOLD_MID=70
THRESHOLD_LOW=50

# Tolerance Settings (percentages)
TOLERANCE_PRICE=5
TOLERANCE_QTY=10

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Alembic Configuration
ALEMBIC_CONFIG=alembic.ini

# Testing
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ap_automation_test
