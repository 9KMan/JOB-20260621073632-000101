# .env.example
# AP Automation Core Engine Configuration

# Database
DATABASE_URL=postgresql+asyncpg://apuser:appassword@localhost:5432/apautomation
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# Security
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Matching Thresholds (percentages 0-100)
THRESHOLD_HIGH=95
THRESHOLD_MID=70
THRESHOLD_LOW=40

# Tolerance Settings (percentages)
TOLERANCE_PRICE=5
TOLERANCE_QTY=10

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=AP Automation Core
DEBUG=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
