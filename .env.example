# .env.example - Environment variables template
# Copy this file to .env and fill in the values

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql+asyncpg://apuser:appass@localhost:5432/apautomation
POSTGRES_USER=apuser
POSTGRES_PASSWORD=appass
POSTGRES_DB=apautomation
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# PGBouncer Configuration
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=5432

# =============================================================================
# Authentication & Security
# =============================================================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Matching Engine Thresholds
# =============================================================================
# Score thresholds for automatic routing (0-100 scale)
THRESHOLD_HIGH=95    # Auto-approve matches above this threshold
THRESHOLD_MID=75     # One-click review for matches above this threshold
THRESHOLD_LOW=50     # Exception/manual review below this threshold

# =============================================================================
# Tolerance Settings
# =============================================================================
# Percentage tolerances for match validation
TOLERANCE_PRICE=5    # Price tolerance percentage
TOLERANCE_QTY=10     # Quantity tolerance percentage

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000
API_HOST=0.0.0.0

# =============================================================================
# CORS Settings
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
