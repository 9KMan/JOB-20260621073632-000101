# .env.example - Environment variables template
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql+asyncpg://apuser:appassword@localhost:5432/apautomation

# Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Matching Thresholds
THRESHOLD_HIGH=90
THRESHOLD_MID=70
THRESHOLD_LOW=50

# Tolerance Settings
TOLERANCE_PRICE=5.0
TOLERANCE_QTY=10.0

# Application
LOG_LEVEL=INFO
APP_NAME=AP Automation Engine
DEBUG=false

# PGBouncer (optional)
# PGBOUNCER_HOST=localhost
# PGBOUNCER_PORT=6432
