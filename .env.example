# .env.example - Environment Variables Template

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_NAME=AP Automation Engine
APP_VERSION=0.1.0

# Database
DATABASE_URL=postgresql+asyncpg://appuser:apppassword@localhost:5432/apautomation
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# PGBouncer (optional - for connection pooling)
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432
PGBOUNCER_USER=appuser
PGBOUNCER_PASSWORD=apppassword

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Matching Thresholds (0.0 - 1.0)
THRESHOLD_HIGH=0.95    # Auto-approve threshold
THRESHOLD_MID=0.75     # 1-click review threshold
THRESHOLD_LOW=0.50     # Exception threshold

# Tolerance Settings (percentage as decimal)
TOLERANCE_PRICE=0.05   # 5% price tolerance
TOLERANCE_QTY=0.10     # 10% quantity tolerance

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Background Workers
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379/0

# OpenTelemetry (observability)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ap-automation-engine
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
