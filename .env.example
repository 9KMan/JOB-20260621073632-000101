# .env.example
# Application
APP_NAME=FinaRo AP Automation
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finaro
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/finaro
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Authentication
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Matching Engine Weights
MATCH_WEIGHT_LINE_LEVEL=0.70
MATCH_WEIGHT_AMOUNT=0.20
MATCH_WEIGHT_DATE=0.10

# Auto-approve threshold (0.0 - 1.0)
AUTO_APPROVE_THRESHOLD=0.85
