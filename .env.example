# Environment Variables Template
# AP Automation Core Engine — FinaRo

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql+asyncpg://apuser:appass123@localhost:5432/apautomation
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# MATCHING ENGINE THRESHOLDS
# =============================================================================
THRESHOLD_HIGH=0.95    # Auto-approve threshold (95%+ confidence)
THRESHOLD_MID=0.75     # 1-click review threshold (75-95% confidence)
THRESHOLD_LOW=0.50     # Exception threshold (50-75% confidence)

# =============================================================================
# MATCHING TOLERANCES
# =============================================================================
TOLERANCE_PRICE=0.05   # 5% price tolerance
TOLERANCE_QTY=0.10     # 10% quantity tolerance

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=AP Automation Engine
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DEBUG=false

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# REDIS (for background jobs if needed)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# TESTING
# =============================================================================
TEST_DATABASE_URL=postgresql+asyncpg://apuser:appass123@localhost:5432/apautomation_test
